# LLM配置
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-dllfyouxputzhdkhfnumbeedysgclbkdpjfkulrnheltghij
LLM_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash
LLM_BASE_URL=https://api.siliconflow.cn/v1/
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# OPENAI_API_KEY=sk-xxxxxxxxxxxx
# OPENAI_MODEL_NAME=gpt-4o-mini
# QWEN_API_KEY=sk-xxxxxxxxxxxx
# QWEN_MODEL_NAME=qwen-plus

# 向量数据库配置
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=cpp_interview_kb

# Embedding配置
EMBEDDING_MODEL=shibing624/text2vec-base-chinese
EMBEDDING_DEVICE=cpu

# 检索配置
RETRIEVAL_THRESHOLD=0.8
RETRIEVAL_TOP_K=5

# 检索配置
RETRIEVAL_THRESHOLD=0.8
RETRIEVAL_TOP_K=5

# 在线搜索配置
SEARCH_ENGINE=tavily  # tavily 或 searxng
TAVILY_API_KEY=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
SEARXNG_URL=http://localhost:8080
SEARCH_TIMEOUT=5

# 回答生成配置
SHORT_ANSWER_MAX_WORDS=200
DETAILED_ANALYSIS_MAX_DEPTH=3

# 服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_MAX_REQUEST_SIZE=10485760  # 10MB

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_DIR=./logs
LOG_FILE_MAX_SIZE=52428800  # 50MB
LOG_FILE_BACKUP_COUNT=10

# CORS配置（开发环境）
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# Redis缓存配置（可选）
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600  # 1小时

# 性能限制
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # 秒
HF_ENDPOINT=https://hf-mirror.com
